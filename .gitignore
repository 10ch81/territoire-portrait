# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local data cache
/data/cache/*
!/data/cache/.gitkeep
!/data/cache/bpe-by-commune.json
!/data/cache/population-by-commune.json
!/data/cache/housing-by-commune.json
!/data/cache/irve-by-commune.json
!/data/cache/fiscal-by-commune.json
!/data/cache/geography-by-commune.json
!/data/cache/bpe-type-labels.json
!/data/cache/social-by-commune.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
